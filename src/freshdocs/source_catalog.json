{
  "rank_basis": "default_seed = GitHut 2024-Q1 event ranks first, filled to 300 with GitHub Linguist programming languages; live mode refreshes GitHut + Linguist.",
  "sources": [
    {
      "id": "github_linguist",
      "kind": "language_universe",
      "url": "https://raw.githubusercontent.com/github/linguist/master/lib/linguist/languages.yml",
      "why": "Canonical GitHub language names, aliases, extensions, and language type."
    },
    {
      "id": "githut_stars",
      "kind": "language_rank",
      "url": "https://raw.githubusercontent.com/madnight/githut/master/src/data/gh-star-event.json",
      "why": "GitHub language ranking by star events."
    },
    {
      "id": "githut_push",
      "kind": "language_rank",
      "url": "https://raw.githubusercontent.com/madnight/githut/master/src/data/gh-push-event.json",
      "why": "GitHub language ranking by push events."
    },
    {
      "id": "githut_pull_request",
      "kind": "language_rank",
      "url": "https://raw.githubusercontent.com/madnight/githut/master/src/data/gh-pull-request.json",
      "why": "GitHub language ranking by pull request events."
    },
    {
      "id": "githut_issue",
      "kind": "language_rank",
      "url": "https://raw.githubusercontent.com/madnight/githut/master/src/data/gh-issue-event.json",
      "why": "GitHub language ranking by issue events."
    },
    {
      "id": "gitstars",
      "kind": "repo_velocity",
      "url": "https://gitstars.io/api/trending",
      "why": "Recent GitHub/GitLab star velocity, useful for fresh tools and agent repos."
    },
    {
      "id": "ghmax",
      "kind": "repo_code_search",
      "url": "local:ghmax",
      "why": "Multi-source repo/code discovery with GitStars harvesting and repo-lake modes."
    },
    {
      "id": "awesome_indexer",
      "kind": "curated_lists",
      "url": "https://github.com/topics/awesome",
      "why": "Awesome-list layer for curated language/tool directories; can be replaced by local awesome-indexer/awesome.db when present."
    },
    {
      "id": "ecosyste_ms_repos",
      "kind": "repo_metadata",
      "url": "https://repos.ecosyste.ms/",
      "why": "Cross-forge repository metadata and dependency intelligence."
    },
    {
      "id": "ossinsight_trending",
      "kind": "repo_velocity",
      "url": "https://ossinsight.io/collections/trending-repos/",
      "why": "Trend and activity layer with language filters."
    }
  ],
